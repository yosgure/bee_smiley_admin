rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isStaff() {
      return isAuthenticated() && request.auth.token.role == 'staff';
    }
    function isParent() {
      return isAuthenticated() && request.auth.token.role == 'parent';
    }
    function uid() {
      return request.auth.uid;
    }
    // KPI権限を付与/変更できるのは上田洋介・上田藍のみ（uid固定）。
    function canGrantKpi() {
      return uid() in [
        'QkWDUJgux7hGkgvZbfzeuJEO4TA2', // 上田 洋介
        'tAo1QynUPgZevJ9iOCqgghHl4fy2'  // 上田 藍
      ];
    }
    match /staffs/{staffId} {
      allow read: if isAuthenticated();
      // kpiAccess を変更する場合は上田2名のみ。それ以外のフィールド更新は従来通り全スタッフ可。
      allow update: if isStaff()
                    && (request.resource.data.get('kpiAccess', false)
                          == resource.data.get('kpiAccess', false)
                        || canGrantKpi());
      allow delete: if isStaff();
      allow create: if false;
    }
    // KPI（OKR週次進捗）。閲覧可否はクライアント側で staffs.kpiAccess により制御。
    // データ自体は機密PIIを含まないためスタッフ全体に read/write を許可。
    match /kpi_categories/{docId} {
      allow read, write: if isStaff();
    }
    match /kpi_weeks/{docId} {
      allow read, write: if isStaff();
    }
    match /kpi_entries/{docId} {
      allow read, write: if isStaff();
    }
    // 体験予約: 枠管理はスタッフのみ。公開フォームの空き枠取得・予約は
    // Cloud Functions（Admin SDK）経由なので公開readは不要。
    match /trial_config/{docId} {
      allow read, write: if isStaff();
    }
    match /trial_slots/{docId} {
      allow read, write: if isStaff();
    }
    match /families/{familyId} {
      allow read: if isAuthenticated();
      allow update: if isStaff()
                    || (isParent() && resource.data.uid == uid());
      allow create, delete: if isStaff();
      match /support_plans/{planId} {
        allow read, write: if isStaff();
      }
    }
    // ビースマイリープラス（児童発達支援/放課後等デイサービス）専用。
    // CRMリード〜入会済み〜HUG連携までの管理対象。
    match /plus_families/{familyId} {
      allow read: if isAuthenticated();
      allow update: if isStaff()
                    || (isParent() && resource.data.uid == uid());
      allow create, delete: if isStaff();
      match /support_plans/{planId} {
        allow read, write: if isStaff();
      }
    }
    match /chat_rooms/{roomId} {
      // roomId が family_{自分のuid} の場合はドキュメント未作成でも read を許可。
      // これが無いと初回ログイン時に「自分の家族ルームを読む → 存在しない →
      // resource.data.members が参照できず permission-denied」というデッドロックで、
      // 保護者がチャット画面で永遠にローディング表示になる。
      allow read: if isStaff()
                  || (isAuthenticated() && resource != null && uid() in resource.data.members)
                  || (isAuthenticated() && roomId == 'family_' + uid());
      // 保護者は自分の家族ルーム(family_{uid})のみ作成可能、かつ members に自分が含まれること。
      allow create: if isStaff()
                    || (isAuthenticated()
                        && roomId == 'family_' + uid()
                        && uid() in request.resource.data.members);
      allow delete: if isStaff();
      allow update: if isStaff()
                    || (isAuthenticated() && uid() in resource.data.members);
      match /messages/{messageId} {
        allow read, create: if isAuthenticated()
                            && uid() in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members;
        allow update: if isAuthenticated()
                      && uid() in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members;
        allow delete: if isAuthenticated()
                      && uid() in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members
                      && resource.data.senderId == uid();
      }
    }
    // チャットのオリジナルスタンプ帳（全員共通）。
    // 誰でも追加・閲覧可。削除はスタッフ or 登録者本人のみ。
    match /chat_stamps/{stampId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.createdBy == uid();
      allow delete: if isStaff()
                    || (isAuthenticated() && resource.data.createdBy == uid());
      allow update: if false;
    }
    match /calendar_events/{eventId} {
      allow read, write: if isStaff();
    }
    match /tasks/{taskId} {
      allow read, write: if isStaff();
    }
    match /campaigns/{campaignId} {
      allow read, create, update, delete: if isStaff();
    }
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    match /assessments/{assessmentId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    // 保護者コンディション記録（プラス保護者向け）。
    // condition_daily: 毎日のキャラ選択・疲れ度（doc id = studentId_YYYY-MM-DD）
    // condition_sheets: 月次かんたんシート（doc id = studentId_YYYY-MM）
    // 保護者は自分の家族（familyUid == uid）の記録のみ読み書き可。
    // doc 未作成時の read は resource == null を許可して not-found を返す
    // （chat_rooms と同じデッドロック回避パターン）。
    match /condition_daily/{docId} {
      allow read: if isStaff()
                  || (isParent() && (resource == null || resource.data.familyUid == uid()));
      allow create: if isStaff()
                  || (isParent() && request.resource.data.familyUid == uid());
      allow update: if isStaff()
                  || (isParent() && resource.data.familyUid == uid()
                      && request.resource.data.familyUid == uid());
      allow delete: if isStaff();
    }
    match /condition_sheets/{docId} {
      allow read: if isStaff()
                  || (isParent() && (resource == null || resource.data.familyUid == uid()));
      allow create: if isStaff()
                  || (isParent() && request.resource.data.familyUid == uid());
      allow update: if isStaff()
                  || (isParent() && resource.data.familyUid == uid()
                      && request.resource.data.familyUid == uid());
      allow delete: if isStaff();
    }
    match /support_plans/{planId} {
      allow read, write: if isStaff();
    }
    match /ai_chat_commands/{docId} {
      allow read, write: if isStaff();
    }
    match /ai_chat_config/{docId} {
      allow read, write: if isStaff();
    }
    match /ai_chat_sessions/{sessionId} {
      allow read, create, update, delete: if isStaff();
      match /messages/{messageId} {
        allow read, write: if isStaff();
      }
    }
    match /plus_lessons/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_lesson_tombstones/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_shifts/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_regular_schedule/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_tasks/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_cell_memos/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_move_alerts/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_student_notes/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_shift_requests/{docId} {
      allow read, write: if isStaff();
    }
    match /plus_settings/{docId} {
      allow read, write: if isStaff();
    }
    // ============================================
    // bee_dashboard_* コレクション群（スタッフ専用）
    // ============================================
    match /bee_dashboard_courses/{docId} {
      allow read, write: if isStaff();
    }
    match /bee_dashboard_schedule/{docId} {
      allow read, write: if isStaff();
    }
    match /bee_dashboard_tasks/{docId} {
      allow read, write: if isStaff();
    }
    // ============================================
    // マスタデータ
    // ============================================
    match /classrooms/{docId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    match /tools/{docId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    match /non_cognitive_skills/{docId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    match /sensitive_periods/{docId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    match /attendance/{docId} {
      allow read, write: if isStaff();
    }
    match /attendance_notifications/{docId} {
      allow read, create: if isStaff();
      allow update, delete: if false;
    }
    match /saved_ai_contents/{docId} {
      allow read, write: if isStaff();
    }
    match /hug_settings/{docId} {
      allow read, write: if isStaff();
    }
    match /hug_sync_logs/{docId} {
      allow read: if isStaff();
      allow write: if false;
    }
    match /ai_student_profiles/{studentId} {
      allow read, write: if isStaff();
      match /session_summaries/{summaryId} {
        allow read, write: if isStaff();
      }
    }
    match /complaint_reports/{reportId} {
      allow read: if isStaff();
      allow create, update, delete: if isStaff();
    }
    match /meeting_minutes/{docId} {
      allow read: if isStaff();
      allow create, update, delete: if isStaff();
    }
    // crm_leads は CRM一体化により plus_families.children[] に統合済み（2026-05-01 削除）。
    // 新規書き込みを禁止し、誤って参照されないよう read もロック。
    match /crm_leads/{leadId} {
      allow read, write: if false;
    }
    match /hiyari_reports/{reportId} {
      function hiyariValid(d) {
        return d.type in ['child', 'environment']
               && (d.type != 'child' || (d.childId is string && d.childId.size() > 0));
      }
      allow read: if isStaff();
      allow create: if isStaff() && hiyariValid(request.resource.data);
      allow update: if isStaff() && hiyariValid(request.resource.data);
      allow delete: if isStaff();
      match /comments/{commentId} {
        allow read, write: if isStaff();
      }
    }
  }
}

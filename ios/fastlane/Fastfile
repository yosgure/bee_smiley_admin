default_platform(:ios)

# App Store Connect API キーのパス（環境変数で上書き可）
ASC_KEY_PATH    = ENV["ASC_API_KEY_PATH"]    || File.expand_path("~/.config/beesmiley/appstore_api.p8")
ASC_KEY_ID      = ENV["ASC_API_KEY_ID"]      || ""
ASC_ISSUER_ID   = ENV["ASC_API_ISSUER_ID"]   || ""

def load_asc_api_key
  app_store_connect_api_key(
    key_id: ASC_KEY_ID,
    issuer_id: ASC_ISSUER_ID,
    key_filepath: ASC_KEY_PATH,
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc "TestFlight に最新のIPAをアップロード"
  lane :beta do
    api_key = load_asc_api_key
    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/bee_smiley_admin.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end

  desc "App Store 審査に提出（TestFlightアップロード→審査送信）"
  lane :release do
    api_key = load_asc_api_key
    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/bee_smiley_admin.ipa",
      skip_waiting_for_build_processing: false,
      skip_submission: true
    )
    deliver(
      api_key: api_key,
      ipa: "../build/ios/ipa/bee_smiley_admin.ipa",
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false
      }
    )
  end
end
